[Unit]
Description=Back up the Shengshi website database and uploads
After=guild-website.service

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/www/shengshi
EnvironmentFile=/etc/shengshi.env
ExecStart=/usr/bin/node server/backup.js
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/www/shengshi/data
