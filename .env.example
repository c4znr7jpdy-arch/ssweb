NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-with-at-least-32-random-characters
REGISTRATION_INVITE_CODE=replace-with-private-invite-code
INITIAL_ADMIN_USERNAME=admin
# Only set this when provisioning the first administrator, then remove it.
INITIAL_ADMIN_PASSWORD=
# Optional absolute path for album files. Defaults to public/uploads/albums.
ALBUM_UPLOAD_DIR=
# Optional backup destination and number of timestamped backups to retain.
BACKUP_DIR=
BACKUP_RETENTION=14
# Optional shared secret for the external bot API.
BOT_API_TOKEN=
# Shared secret used by the WPS AirScript roster sync endpoint.
KDOCS_SYNC_TOKEN=
# AirScript webhook used to push website signups back into the shared sheet.
KDOCS_WEBHOOK_URL=
KDOCS_API_TOKEN=
KDOCS_EVENT_TITLE=双10
KDOCS_WEBSITE_TO_SHEET_ENABLED=false
